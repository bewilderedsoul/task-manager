# ── Server ─────────────────────────────────────────────
PORT=8080
# Comma-separated list of origins allowed by CORS (the frontend URL).
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL / Neon) ───────────────────────
# Neon connection string. Must include sslmode=require for Neon.
# Example: postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/taskmanager?sslmode=disable

# ── Auth ───────────────────────────────────────────────
# Long random secret used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
# Token lifetime in hours.
JWT_TTL_HOURS=72
